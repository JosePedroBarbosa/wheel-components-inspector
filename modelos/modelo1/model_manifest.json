{
  "model_name": "wheel-components-inspector",
  "version": "1.0.0",
  "task": "object_detection",
  "framework": "ultralytics-yolo",
  "weights": {
    "primary": "modelos/weights.pt"
  },
  "classes": [
    { "name": "jante", "aliases": ["rim", "wheel hub"] },
    { "name": "parafuso", "aliases": ["bolt", "screw", "lug nut"] },
    { "name": "roda", "aliases": ["wheel", "tire"] }
  ],
  "intended_use": {
    "summary": "Detect wheel components (rims, bolts, full wheels) for automotive visual inspection.",
    "environment": ["workshop", "garage", "outdoor parking", "assembly line"],
    "out_of_scope": [
      "detect damage or wear on wheel components",
      "classify tire brands or models",
      "measure bolt torque"
    ]
  },
  "data": {
    "dataset_format": "yolo",
    "image_count": { "train": 0, "val": 0, "test": 0 },
    "source": "collected_by_students",
    "labeling_tool": "Roboflow",
    "labeling_notes": "Bounding boxes cover the visible extent of each component. Partially occluded objects are labeled if >30% visible."
  },
  "training": {
    "base_model": "yolov8m.pt",
    "epochs": 100,
    "imgsz": 640,
    "batch": 16,
    "patience": 50,
    "optimizer": "auto",
    "lr0": 0.01,
    "augmentations": ["hsv_shift", "horizontal_flip", "scale", "mosaic"]
  },
  "evaluation": {
    "test_metrics": {
      "map50": null,
      "map5095": null,
      "per_class_ap50": { "jante": null, "parafuso": null, "roda": null }
    },
    "recommended_thresholds": { "confidence": 0.25, "nms_iou": 0.7 }
  },
  "io": {
    "input": { "type": "image", "color_space": "RGB", "resize": 640 },
    "output": { "format": "detections_json", "bbox": "xyxy", "score": "confidence" }
  },
  "limitations": [
    "Performance may drop on highly reflective rims with direct glare.",
    "Small bolts (<30px) at distance may be missed.",
    "Trained on daylight/indoor images; night conditions are untested."
  ],
  "runtime": {
    "model_size_mb": null,
    "latency_ms_cpu": null,
    "latency_ms_gpu": null
  },
  "license": {
    "model": "CC-BY-4.0",
    "data": "CC-BY-4.0",
    "notes": "No personally identifiable information in dataset. No proprietary logos intentionally captured."
  }
}
